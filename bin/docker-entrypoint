#!/bin/bash -e

# If running any Rails command, setup databases
if [[ "${*}" == *"./bin/rails"* ]] || [[ "${*}" == *"solid_queue"* ]]; then
  echo "🚀 Setting up databases for Rails application..."

  # Setup primary and queue databases
  ./bin/rails db:prepare

  # The solid_queue:setup task is automatically called by db:prepare
  # via the Rake task enhancement in lib/tasks/solid_queue.rake

  echo "✅ Database setup completed"
fi

exec "${@}"
