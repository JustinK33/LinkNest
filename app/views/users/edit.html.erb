<% content_for :title, "Edit Profile - LinkNest" %>

<div class="container-md" style="padding-top: 2rem; padding-bottom: 4rem;">
  <div class="form-container">
    <div class="form-header">
      <h1>Edit profile</h1>
      <p>Update your public profile details</p>
    </div>

    <% if @user.errors.any? %>
      <div class="error-messages">
        <h3>Please fix the following:</h3>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user do |form| %>
      <div class="form-group">
        <%= form.label :avatar, "Profile picture" %>
        <% if @user.avatar.attached? %>
          <div style="margin-bottom: 0.75rem;">
            <%= image_tag @user.avatar, alt: "Current profile picture", style: "width: 72px; height: 72px; object-fit: cover; border-radius: 999px; border: 1px solid var(--color-gray-200);" %>
          </div>
        <% elsif @user.avatar_url.present? %>
          <div style="margin-bottom: 0.75rem;">
            <%= image_tag @user.avatar_url, alt: "Current profile picture", style: "width: 72px; height: 72px; object-fit: cover; border-radius: 999px; border: 1px solid var(--color-gray-200);" %>
          </div>
        <% end %>
        <%= form.file_field :avatar, accept: "image/png,image/jpeg,image/webp" %>
        <div class="form-hint">PNG, JPG, or WEBP. Max size 5MB.</div>
      </div>

      <div class="form-group">
        <%= form.label :username, "Username" %>
        <%= form.text_field :username, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :bio, "About me" %>
        <%= form.text_area :bio, rows: 5, placeholder: "Tell people who you are and what you do" %>
        <div class="form-hint">This appears on your public profile</div>
      </div>

      <div class="form-group">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email, placeholder: "your@email.com" %>
        <div class="form-hint">Optional. Will be displayed on your public profile</div>
      </div>

      <div class="form-group">
        <%= form.label :phone_number, "Phone number" %>
        <%= form.telephone_field :phone_number, placeholder: "+1 (555) 123-4567" %>
        <div class="form-hint">Optional. Will be displayed on your public profile</div>
      </div>

      <div class="btn-group" style="margin-top: 2rem;">
        <%= form.submit "Save profile", class: "btn btn-primary" %>
        <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
