<% content_for :title, "Edit Profile - LinkNest" %>

<div class="container-md" style="padding-top: 2rem; padding-bottom: 4rem;">
  <div class="form-container">
    <div class="form-header">
      <h1>Edit profile</h1>
      <p>Update your public profile details</p>
    </div>

    <% if @user.errors.any? %>
      <div class="error-messages">
        <h3>Please fix the following:</h3>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user do |form| %>
      <div class="form-group">
        <%= form.label :avatar, "Profile picture" %>
        <% if @user.avatar.attached? %>
          <div style="margin-bottom: 0.75rem;">
            <%= image_tag @user.avatar, alt: "Current profile picture", style: "width: 72px; height: 72px; object-fit: cover; border-radius: 999px; border: 1px solid var(--color-gray-200);" %>
          </div>
        <% elsif @user.avatar_url.present? %>
          <div style="margin-bottom: 0.75rem;">
            <%= image_tag @user.avatar_url, alt: "Current profile picture", style: "width: 72px; height: 72px; object-fit: cover; border-radius: 999px; border: 1px solid var(--color-gray-200);" %>
          </div>
        <% end %>
        <%= form.file_field :avatar, accept: "image/png,image/jpeg,image/webp" %>
        <div class="form-hint">PNG, JPG, or WEBP. Max size 5MB.</div>
      </div>

      <div class="form-group">
        <%= form.label :username, "Username" %>
        <%= form.text_field :username, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :bio, "About me" %>
        <%= form.text_area :bio, rows: 5, placeholder: "Tell people who you are and what you do" %>
        <div class="form-hint">This appears on your public profile</div>
      </div>

      <% if User.column_names.include?('email') || User.column_names.include?('phone_number') %>
        <div class="contact-fields-section" style="margin-top: 2rem;">
          <h3 style="margin-bottom: 0.5rem; color: var(--color-gray-800); font-size: 1.1rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-size: 1.2rem;">💼</span>
            Contact Information
          </h3>
          <p style="margin-bottom: 1.5rem; color: var(--color-gray-600); font-size: 0.9rem; line-height: 1.4;">
            Add contact details that will be displayed on your public profile. These are completely optional.
          </p>

          <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
            <% if User.column_names.include?('email') %>
              <div class="contact-field-input">
                <label for="user_email" class="contact-field-label">
                  <span class="contact-field-icon">📧</span>
                  Email Address
                </label>
                <%= form.email_field :email,
                                     placeholder: "your@email.com",
                                     style: "width: 100%; padding: 0.75rem 0.75rem 0.75rem 2.5rem; font-size: 0.95rem;" %>
                <div class="contact-hint">
                  Displayed publicly with a clickable mailto link
                </div>
              </div>
            <% end %>

            <% if User.column_names.include?('phone_number') %>
              <div class="contact-field-input">
                <label for="user_phone_number" class="contact-field-label">
                  <span class="contact-field-icon">📞</span>
                  Phone Number
                </label>
                <%= form.telephone_field :phone_number,
                                         placeholder: "+1 (555) 123-4567",
                                         style: "width: 100%; padding: 0.75rem 0.75rem 0.75rem 2.5rem; font-size: 0.95rem;" %>
                <div class="contact-hint">
                  Displayed publicly with a clickable call link
                </div>
              </div>
            <% end %>
          </div>

          <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(86, 115, 140, 0.1);">
            <p style="font-size: 0.8rem; color: var(--color-gray-500); text-align: center; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
              <span>🔒</span>
              Your contact information is only shown on your public profile when you choose to add it
            </p>
          </div>
        </div>
      <% end %>

      <div class="btn-group" style="margin-top: 2rem;">
        <%= form.submit "Save profile", class: "btn btn-primary" %>
        <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
