<% content_for :title, "New Link - LinkNest" %>
<% mode = @entry_mode.presence_in(["link", "file"]) || "link" %>

<div class="container-md" style="padding-top: 2rem; padding-bottom: 4rem;">
  <div class="form-container">
    <div class="form-header">
      <h1><%= mode == "file" ? "Upload a PDF file" : "Create a new link" %></h1>
      <p><%= mode == "file" ? "Upload a PDF with preview and download" : "Add a link to share on your public profile" %></p>
    </div>

    <%= form_with model: @link do |form| %>
      <%= render "form", form: form %>
    <% end %>
  </div>
</div>
