<% content_for :title, "Edit Link - LinkNest" %>
<% mode = @entry_mode.presence_in(["link", "file"]) || "link" %>

<div class="container-md" style="padding-top: 2rem; padding-bottom: 4rem;">
  <div class="form-container">
    <div class="form-header">
      <h1><%= mode == "file" ? "Edit file" : "Edit link" %></h1>
      <p><%= mode == "file" ? "Update PDF, preview, and download options" : "Update your link details" %></p>
    </div>

    <%= form_with model: @link do |form| %>
      <%= render "form", form: form %>
    <% end %>
  </div>
</div>
