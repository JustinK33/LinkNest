<% if @link.errors.any? %>
  <div class="error-messages">
    <h3>Please fix the following:</h3>
    <ul>
      <% @link.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% mode = @entry_mode.presence_in(["link", "file"]) || "link" %>

<div class="form-group">
  <label>What do you want to add?</label>
  <div class="entry-mode-actions">
    <% mode_link_path = @link.persisted? ? edit_link_path(@link, mode: "link") : new_link_path(mode: "link") %>
    <% mode_file_path = @link.persisted? ? edit_link_path(@link, mode: "file") : new_link_path(mode: "file") %>
    <%= link_to "Add link", mode_link_path, class: "btn btn-sm #{mode == 'link' ? 'btn-primary' : 'btn-secondary'}" %>
    <%= link_to "Add file", mode_file_path, class: "btn btn-sm #{mode == 'file' ? 'btn-primary' : 'btn-secondary'}" %>
  </div>
  <div class="form-hint">No combined mode. Choose one type for this item.</div>
</div>

<%= hidden_field_tag :entry_mode, mode %>

<div class="form-group">
  <%= form.label :title, "Link title" %>
  <%= form.text_field :title,
                      required: true,
                      placeholder: "My Portfolio" %>
  <div class="form-hint">Give your link a descriptive name</div>
</div>

<% if Link.column_names.include?('public') %>
<div class="form-group">
  <div style="display: flex; align-items: center; gap: 0.75rem;">
    <%= form.check_box :public, { style: "width: auto; margin: 0;" } %>
    <label for="link_public" style="margin: 0; cursor: pointer; font-weight: 500;">
      Show on public profile
    </label>
  </div>
  <div class="form-hint">Only public links appear on your public profile</div>
</div>
<% end %>

<% if mode == "link" %>
  <div class="form-group" id="url_field_group">
    <%= form.label :url, "URL" %>
    <%= form.url_field :url,
                       required: true,
                       placeholder: "https://example.com" %>
    <div class="form-hint">Use this for websites, social links, email, or phone links</div>
  </div>
<% end %>

<% if mode == "file" %>
  <div class="form-group" id="file_field_group">
    <%= form.label :resume_pdf, "PDF file" %>
    <div class="file-input-wrapper">
      <%= form.file_field :resume_pdf, accept: "application/pdf", id: "file_input_#{@link.id || 'new'}" %>
      <div class="file-input-display">
        <span class="file-input-icon">📄</span>
        <span class="file-input-text">Choose a PDF file or drag it here</span>
      </div>
    </div>
    <div class="form-hint">Only PDF files are accepted</div>

    <% if @link.resume_pdf.attached? && @link.persisted? %>
      <div class="mt-2" style="color: var(--color-gray-700); display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--color-success); font-weight: 600;">✓</span>
        <span>Current file: <strong><%= @link.resume_pdf.filename.to_s %></strong></span>
      </div>

      <div class="mt-2" style="display: flex; align-items: center; gap: 0.75rem;">
        <%= link_to "👁 Preview", rails_blob_path(@link.resume_pdf, only_path: true), class: "link-action" %>
        <span style="color: var(--color-gray-400);">•</span>
        <%= link_to "⬇ Download", rails_blob_path(@link.resume_pdf, disposition: "attachment", only_path: true), rel: "noopener noreferrer", class: "link-action" %>
      </div>

      <div class="mt-3" style="display: flex; align-items: center; gap: 0.5rem;">
        <%= form.check_box :remove_resume_pdf, { style: "width: auto; margin: 0;" }, "1", "0" %>
        <span style="color: var(--color-gray-600);">Replace with a new PDF</span>
      </div>
    <% end %>
  </div>

  <script>
    (function() {
      const fileInput = document.getElementById("file_input_<%= @link.id || 'new' %>");
      const fileDisplay = document.querySelector(".file-input-display");

      if (!fileInput || !fileDisplay) return;

      const updateDisplay = function() {
        if (fileInput.files && fileInput.files[0]) {
          const filename = fileInput.files[0].name;
          fileDisplay.innerHTML = '<span style="color: var(--color-success); font-weight: 600;">✓</span> <span class="file-input-text">' + filename + '</span>';
        }
      };

      fileInput.addEventListener("change", updateDisplay);

      // Drag and drop
      const wrapper = fileInput.closest(".file-input-wrapper");
      if (wrapper) {
        ["dragenter", "dragover", "dragleave", "drop"].forEach(eventName => {
          wrapper.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
          e.preventDefault();
          e.stopPropagation();
        }

        ["dragenter", "dragover"].forEach(eventName => {
          wrapper.addEventListener(eventName, highlight, false);
        });

        ["dragleave", "drop"].forEach(eventName => {
          wrapper.addEventListener(eventName, unhighlight, false);
        });

        function highlight(e) {
          wrapper.style.borderColor = "var(--color-primary)";
          wrapper.style.backgroundColor = "var(--color-primary-subtle)";
        }

        function unhighlight(e) {
          wrapper.style.borderColor = "var(--color-gray-200)";
          wrapper.style.backgroundColor = "var(--color-gray-50)";
        }

        wrapper.addEventListener("drop", handleDrop, false);

        function handleDrop(e) {
          const dt = e.dataTransfer;
          const files = dt.files;
          fileInput.files = files;
          updateDisplay();
        }
      }
    })();
  </script>
<% end %>

<div class="btn-group" style="margin-top: 2rem;">
  <%= form.submit(mode == "file" ? "Save file" : "Save link", class: "btn btn-primary") %>
  <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
</div>

