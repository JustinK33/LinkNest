<% content_for :title, "#{@user.first_name} #{@user.last_name} (@#{@user.slug}) - LinkNest" %>

<div class="container-sm" style="padding-top: 2rem; padding-bottom: 4rem;" data-controller="profile">
  <!-- Public Profile Header -->
  <div class="card">
    <div class="profile-card">
      <div class="profile-avatar" style="width: 120px; height: 120px; font-size: 2.5rem; background-color: <%= @user.profile_color %>; display: flex; align-items: center; justify-content: center; color: white; border-radius: 50%;">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, alt: "#{@user.first_name} #{@user.last_name}", style: "width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" %>
        <% elsif @user.avatar_url.present? %>
          <%= image_tag @user.avatar_url, alt: "#{@user.first_name} #{@user.last_name}", style: "width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" %>
        <% else %>
          <%= "#{@user.first_name} #{@user.last_name}".split.map(&:first).join.upcase %>
        <% end %>
      </div>
      
      <div class="profile-info">
        <div class="profile-name">
          <%= "#{@user.first_name} #{@user.last_name}" %>
        </div>
        <div class="profile-username">
          @<%= @user.slug %>
        </div>
        <h3 style="margin-bottom: 0.5rem;">About me</h3>
        <% if @user.bio.present? %>
          <div class="profile-bio">
            <%= simple_format(@user.bio) %>
          </div>
        <% else %>
          <div class="profile-bio" style="color: var(--color-gray-400); font-style: italic;">
            This user hasn't added an About me yet.
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- QR Code Section -->
  <div class="card" style="margin-top: 2rem; text-align: center;">
    <h3 style="margin-bottom: 1rem; color: var(--color-gray-700);">💫 Share this Profile</h3>
    <p style="margin-bottom: 1.5rem; color: var(--color-gray-600);">Scan or tap to share this LinkNest profile</p>

    <div class="qr-code-container" style="display: inline-block; padding: 1.5rem; background: white; border-radius: var(--radius-lg); box-shadow: var(--shadow-md); border: 1px solid var(--color-gray-100);">
      <%= image_tag "data:image/png;base64,#{Base64.encode64(@qr_png.to_s)}",
                    alt: "QR Code for #{@user.first_name}'s profile",
                    style: "width: 200px; height: 200px; display: block;" %>
    </div>

    <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
      <%= link_to "📱 Download QR Code", user_qr_code_path(@user),
                  class: "btn btn-secondary btn-sm" %>
      <button onclick="shareProfile()" class="btn btn-primary btn-sm">
        📤 Share Profile
      </button>
    </div>
  </div>

  <!-- Public Links -->
  <% if @links.any? %>
    <div style="margin-top: 2rem;">
      <ul class="public-links-list">
        <% @links.each do |link| %>
          <li>
                <%= link_to(safe_link_href(link.url), class: "public-link-card", data: { action: "click->profile#trackClick", link_id: link.id }) do %>              <h3 class="public-link-title">
                <%= link.title %>
              </h3>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="card" style="margin-top: 2rem;">
      <div class="empty-state">
        <div class="empty-state-icon">🔗</div>
        <h3>No links yet</h3>
        <p>@<%= @user.slug %> hasn't shared any links yet</p>
      </div>
    </div>
  <% end %>

  <!-- Footer attribution -->
  <div style="text-align: center; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-gray-200);">
    <p style="color: var(--color-gray-500); font-size: 0.875rem;">
      Powered by <%= link_to "LinkNest", root_path %> 
    </p>
  </div>
</div>

<script>
  async function shareProfile() {
    const profileUrl = window.location.href;
    const profileTitle = "<%= "#{@user.first_name} #{@user.last_name}" %>'s LinkNest Profile";

    // Check if Web Share API is supported
    if (navigator.share) {
      try {
        await navigator.share({
          title: profileTitle,
          text: "Check out my networking profile on LinkNest!",
          url: profileUrl
        });
      } catch (error) {
        if (error.name !== 'AbortError') {
          console.error('Error sharing:', error);
          fallbackShare(profileUrl);
        }
      }
    } else {
      fallbackShare(profileUrl);
    }
  }

  function fallbackShare(url) {
    // Copy to clipboard as fallback
    navigator.clipboard.writeText(url).then(() => {
      // Show a temporary success message
      const button = event.target;
      const originalText = button.textContent;
      button.textContent = '✅ Copied!';
      button.style.background = 'var(--color-success)';

      setTimeout(() => {
        button.textContent = originalText;
        button.style.background = '';
      }, 2000);
    }).catch(err => {
      console.error('Could not copy text: ', err);
      alert('Share URL: ' + url);
    });
  }
</script>
