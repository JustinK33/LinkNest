<% content_for :title, "Dashboard - LinkNest" %>

<div class="dashboard-editor">
  <div class="dashboard-workspace-tabs" role="tablist" aria-label="Editor tabs">
    <button type="button" class="workspace-tab is-active" data-tab="profile" role="tab" aria-selected="true">👤 Profile</button>
    <button type="button" class="workspace-tab" data-tab="links" role="tab" aria-selected="false">🔗 Links</button>
    <button type="button" class="workspace-tab" data-tab="share" role="tab" aria-selected="false">📤 Share</button>
    <button type="button" class="workspace-tab" data-tab="preview" role="tab" aria-selected="false">🧾 Preview</button>
  </div>

  <div class="dashboard-editor-shell container-md">
    <section class="workspace-panel is-active" data-panel="profile">
      <div class="dashboard-profile-header">
        <div class="dashboard-profile-avatar" style="background-color: <%= @user.profile_color.presence || '#0ea5e9' %>;">
          <% if @user.avatar_url.present? %>
            <%= image_tag @user.avatar_url, alt: "#{@user.first_name} #{@user.last_name}", class: "dashboard-profile-image" %>
          <% else %>
            <%= "#{@user.first_name} #{@user.last_name}".split.map(&:first).join.upcase %>
          <% end %>
        </div>

        <h1 class="dashboard-profile-name"><%= @user.username %></h1>
        <p class="dashboard-profile-url"><%= link_to "#{request.base_url}#{user_profile_path(@user.slug)}", user_profile_path(@user.slug) %></p>
      </div>

      <article class="dashboard-card">
        <header class="dashboard-card-header">
          <h2>General info</h2>
          <%= link_to "✎", edit_user_path(@user), class: "dashboard-icon-action", aria: { label: "Edit profile" } %>
        </header>

        <div class="dashboard-card-section">
          <p class="dashboard-label">Profile name</p>
          <p class="dashboard-value"><%= @user.username %></p>
        </div>

        <div class="dashboard-card-section">
          <p class="dashboard-label">About me</p>
          <% if @user.bio.present? %>
            <p class="dashboard-value"><%= @user.bio %></p>
          <% else %>
            <p class="dashboard-value dashboard-muted">No about me yet</p>
          <% end %>
        </div>

        <p class="dashboard-status">● Profile is enabled</p>
      </article>

      <article class="dashboard-card">
        <header class="dashboard-card-header">
          <h2>Alias</h2>
          <%= link_to "↗", user_profile_path(@user.slug), class: "dashboard-icon-action", aria: { label: "Open public profile" } %>
        </header>

        <p class="dashboard-alias"><%= link_to "@#{@user.slug}", user_profile_path(@user.slug) %></p>
      </article>
    </section>

    <section class="workspace-panel" data-panel="links" hidden>
      <div class="dashboard-links-header">
        <h2>Network</h2>
        <div class="dashboard-links-cta-group">
          <%= link_to "Add link", new_link_path(mode: "link"), class: "btn btn-secondary btn-sm" %>
          <%= link_to "Add file", new_link_path(mode: "file"), class: "btn btn-primary btn-sm" %>
        </div>
      </div>

      <% if @links.any? %>
        <div class="dashboard-links-list" data-reorder-url="<%= reorder_links_path %>">
          <% @links.each do |link| %>
            <% link_label =
               if link.resume_pdf.attached?
                 "Resume"
               elsif link.url.to_s.start_with?("mailto:")
                 "Email"
               elsif link.url.to_s.start_with?("tel:")
                 "Phone"
               else
                 "Url"
               end %>

            <article class="dashboard-link-card" draggable="true" data-link-id="<%= link.id %>">
              <div class="dashboard-link-content">
                <p class="dashboard-link-title"><%= link_label %> - <%= link.title %></p>
                <p class="dashboard-link-url">
                  <% if link.resume_pdf.attached? %>
                    <%= link_to link.resume_pdf.filename.to_s, rails_blob_path(link.resume_pdf, only_path: true) %>
                  <% else %>
                    <%= link_to link.url, link.url %>
                  <% end %>
                </p>

                <% if link.resume_pdf.attached? %>
                  <p class="dashboard-file-actions">
                    <%= link_to "Preview", rails_blob_path(link.resume_pdf, only_path: true) %>
                    <span>•</span>
                    <%= link_to "Download", rails_blob_path(link.resume_pdf, disposition: "attachment", only_path: true), rel: "noopener noreferrer" %>
                  </p>
                <% end %>
              </div>

              <div class="dashboard-link-actions">
                <%= link_to "✎", edit_link_path(link), class: "dashboard-icon-action", aria: { label: "Edit #{link.title}" } %>
                <%= button_to "🗑", link_path(link), method: :delete, class: "dashboard-icon-action danger", form_class: "dashboard-inline-form", form: { data: { turbo_confirm: "Delete this link?" } }, aria: { label: "Delete #{link.title}" } %>
                <span class="dashboard-drag-hint" aria-hidden="true">⋮⋮</span>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <article class="dashboard-card empty">
          <h3>No links yet</h3>
          <p>Add your first link to start building your profile.</p>
        </article>
      <% end %>
    </section>

    <section class="workspace-panel" data-panel="share" hidden>
      <article class="dashboard-card empty">
        <h3>Share is coming soon</h3>
        <p>Use your public URL to share your page today.</p>
      </article>
    </section>

    <section class="workspace-panel" data-panel="preview" hidden>
      <article class="dashboard-card empty">
        <h3>Preview is coming soon</h3>
        <p>Open your live page at <%= link_to user_profile_path(@user.slug), user_profile_path(@user.slug) %>.</p>
      </article>
    </section>
  </div>
</div>

<script>
  function initializeDashboardTabs() {
    const root = document.querySelector(".dashboard-editor");
    if (!root || root.dataset.tabsInitialized === "true") {
      return;
    }

    const tabs = Array.from(root.querySelectorAll(".workspace-tab"));
    const panels = Array.from(root.querySelectorAll(".workspace-panel"));
    const tabsBar = root.querySelector(".dashboard-workspace-tabs");
    if (!tabsBar) {
      return;
    }

    tabsBar.addEventListener("click", function(event) {
      const tab = event.target.closest(".workspace-tab");
      if (!tab) {
        return;
      }

      const panelName = tab.dataset.tab;

      tabs.forEach(function(item) {
        item.classList.toggle("is-active", item === tab);
        item.setAttribute("aria-selected", String(item === tab));
      });

      panels.forEach(function(panel) {
        const isTarget = panel.dataset.panel === panelName;
        panel.classList.toggle("is-active", isTarget);
        panel.hidden = !isTarget;
      });
    });

    root.dataset.tabsInitialized = "true";
  }

  document.addEventListener("DOMContentLoaded", initializeDashboardTabs);
  document.addEventListener("turbo:load", initializeDashboardTabs);

  function initializeLinkReorder() {
    const list = document.querySelector(".dashboard-links-list");
    if (!list || list.dataset.reorderInitialized === "true") {
      return;
    }

    const reorderUrl = list.dataset.reorderUrl;
    const csrf = document.querySelector("meta[name='csrf-token']")?.content;
    let draggedCard = null;

    function persistOrder() {
      if (!reorderUrl || !csrf) {
        return;
      }

      const orderedIds = Array.from(list.querySelectorAll(".dashboard-link-card")).map(function(card) {
        return Number(card.dataset.linkId);
      });

      fetch(reorderUrl, {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": csrf,
          "Accept": "application/json"
        },
        body: JSON.stringify({ ordered_ids: orderedIds })
      });
    }

    list.querySelectorAll(".dashboard-link-card").forEach(function(card) {
      card.addEventListener("dragstart", function() {
        draggedCard = card;
        card.classList.add("is-dragging");
      });

      card.addEventListener("dragend", function() {
        card.classList.remove("is-dragging");
        draggedCard = null;
        persistOrder();
      });

      card.addEventListener("dragover", function(event) {
        event.preventDefault();
        if (!draggedCard || draggedCard === card) {
          return;
        }

        const bounds = card.getBoundingClientRect();
        const shouldInsertBefore = event.clientY < bounds.top + bounds.height / 2;
        list.insertBefore(draggedCard, shouldInsertBefore ? card : card.nextSibling);
      });
    });

    list.dataset.reorderInitialized = "true";
  }

  document.addEventListener("DOMContentLoaded", initializeLinkReorder);
  document.addEventListener("turbo:load", initializeLinkReorder);
</script>
