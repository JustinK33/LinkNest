<% content_for :title, "LinkNest - Your Links, Your Way" %>

<% if authenticated? %>
  <section class="home-auth">
    <div class="container-md home-auth-inner">
      <p class="home-auth-kicker">Welcome back</p>
      <h1>Everything is ready, <%= current_user.first_name %>.</h1>
      <p class="home-auth-copy">Manage your links, upload your resume, and publish updates in seconds.</p>
      <div class="home-auth-actions">
        <%= link_to "Open Dashboard", dashboard_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "View Public Profile", public_profile_url(current_user), class: "btn btn-secondary btn-lg" %>
      </div>
    </div>
  </section>
<% else %>
  <section class="landing-hero">
    <div class="container-md landing-hero-inner">
      <div class="landing-mark"><%= image_tag "/linktestlogo.png", alt: "LinkNest logo", class: "landing-logo-image" %></div>
      <h1>One page for every important link.</h1>
      <p>Build your profile, add links and resume files, then share one clean URL everywhere you show up online.</p>
      <div class="landing-hero-actions">
        <%= link_to "Create Account", new_user_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "Sign In", new_session_path, class: "btn btn-secondary btn-lg" %>
      </div>
    </div>
  </section>

  <section class="landing-feature-band">
    <div class="container landing-feature-grid">
      <div class="landing-phone-mock" aria-hidden="true">
        <div class="landing-phone-brand">
          <div class="landing-phone-logo"><%= image_tag "/linktestlogo.png", alt: "LinkNest logo", class: "phone-logo-image" %></div>
          <p class="phone-title">LinkNest</p>
          <p class="phone-subtitle">One link for all your links</p>
        </div>

        <p class="phone-section-title">Contact</p>
        <ul class="landing-phone-list">
          <li>Website</li>
          <li>Email</li>
          <li>Phone</li>
          <li>Resume PDF</li>
        </ul>

        <p class="phone-section-title">Social</p>
        <ul class="landing-phone-list">
          <li>LinkedIn</li>
          <li>GitHub</li>
          <li>Instagram</li>
          <li>YouTube</li>
        </ul>
      </div>

      <div class="landing-feature-copy">
        <h2>A clean, fast way to build your personal link page.</h2>
        <div class="landing-feature-list">
          <article>
            <h3><span>◈</span> Unique URL</h3>
            <p>Share one profile address across resumes, social bios, and email signatures.</p>
          </article>
          <article>
            <h3><span>◈</span> Unlimited entries</h3>
            <p>Add as many links as you need for work, socials, projects, and contact options.</p>
          </article>
          <article>
            <h3><span>◈</span> Organized sections</h3>
            <p>Keep content readable by grouping links into clear categories.</p>
          </article>
          <article>
            <h3><span>◈</span> Easy sharing</h3>
            <p>Publish one page that visitors can open from any device.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="landing-cta-slice">
    <div class="container landing-cta-grid">
      <div class="landing-cta-copy">
        <h2>Create and share your digital profile card.</h2>
        <p>Set up your personal link page in minutes. Keep your key links and resume in sync as your work evolves.</p>
        <%= link_to "Start Free", new_user_path, class: "btn btn-primary btn-lg" %>
      </div>

      <div class="landing-card-stack" aria-hidden="true">
        <div class="profile-card-back"></div>
        <div class="profile-card-front">
          <div class="card-avatar">JD</div>
          <p class="card-name">Your Profile</p>
          <p class="card-role">Designer, Developer, Creator</p>
          <div class="card-mini-actions">
            <span>Call</span>
            <span>Email</span>
            <span>Resume</span>
          </div>
        </div>
      </div>
    </div>
  </section>
<% end %>
